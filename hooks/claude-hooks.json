{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST -H 'Content-Type: application/json' -H \"Authorization: Bearer $AGENT_HUD_TOKEN\" -d \"$(cat)\" http://localhost:7420/api/v1/hooks/session-start",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST -H 'Content-Type: application/json' -H \"Authorization: Bearer $AGENT_HUD_TOKEN\" -d \"$(cat)\" http://localhost:7420/api/v1/hooks/post-tool-use",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST -H 'Content-Type: application/json' -H \"Authorization: Bearer $AGENT_HUD_TOKEN\" -d \"$(cat)\" http://localhost:7420/api/v1/hooks/post-tool-use-failure",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST -H 'Content-Type: application/json' -H \"Authorization: Bearer $AGENT_HUD_TOKEN\" -d \"$(cat)\" http://localhost:7420/api/v1/hooks/notification",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST -H 'Content-Type: application/json' -H \"Authorization: Bearer $AGENT_HUD_TOKEN\" -d \"$(cat)\" http://localhost:7420/api/v1/hooks/stop",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST -H 'Content-Type: application/json' -H \"Authorization: Bearer $AGENT_HUD_TOKEN\" -d \"$(cat)\" http://localhost:7420/api/v1/hooks/session-end",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
